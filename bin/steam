#!/bin/sh

PLIST_NAME="com.codeweavers.CrossOver.license.plist"
PLIST_PATH="$HOME/Library/Preferences/$PLIST_NAME"
BOTTLES_PATH="$HOME/Library/Application Support/CrossOver/Bottles"

TOTAL_STEPS=3
STEP=0

function addStep() {
  ((STEP++))
  echo ""
  echo "\033[33m$STEP/$TOTAL_STEPS $1\033[0m"
}

function logInfo() {
  printf '\033[36m[log]\033[0m %s\n' "$1" >&2
}

function describePath() {
  local path="$1"

  if [ -L "$path" ]; then
    printf 'symlink -> %s' "$(readlink "$path")"
    return
  fi

  if [ -d "$path" ]; then
    printf 'directory'
    return
  fi

  if [ -f "$path" ]; then
    printf 'file'
    return
  fi

  if [ -e "$path" ]; then
    printf 'exists'
    return
  fi

  printf 'missing'
}

function logFileAction() {
  local action="$1"
  local path="$2"
  local details="$3"

  if [[ -n "$details" ]]; then
    logInfo "$action -> $path ($details)"
    return
  fi

  logInfo "$action -> $path"
}

function removePath() {
  local path="$1"

  logFileAction "remove" "$path" "$(describePath "$path")"
  if ! rm -rf "$path"; then
    logFileAction "remove:error" "$path" "failed to remove path"
    return 1
  fi

  logFileAction "remove:result" "$path" "$(describePath "$path")"
}

function writePreferenceDate() {
  local key="$1"
  local value="$2"

  logFileAction "defaults:write" "$PLIST_PATH" "$key=$value"
  if ! defaults write com.codeweavers.CrossOver "$key" -date "$value"; then
    logFileAction "defaults:error" "$PLIST_PATH" "failed to write $key"
    return 1
  fi

  logFileAction "defaults:result" "$PLIST_PATH" "$(describePath "$PLIST_PATH")"
}

function resetSystemReg() {
  local arquivo="$1"
  local data_atual=$(date +%Y-%m-%d)
  local backup_arquivo="${arquivo}.${data_atual}.bak"
  local temp_arquivo="${arquivo}.tmp"

  logFileAction "read" "$arquivo" "$(describePath "$arquivo")"

  # Make a backup copy of the original file with the current date in the name
  logFileAction "backup:create" "$backup_arquivo" "copy of $arquivo"
  if ! cp "$arquivo" "$backup_arquivo"; then
    logFileAction "backup:error" "$backup_arquivo" "failed to create backup"
    return 1
  fi

  logFileAction "backup:result" "$backup_arquivo" "$(describePath "$backup_arquivo")"

  # proccess the file, removing the desired section
  logFileAction "rewrite:temp" "$temp_arquivo" "filtered copy of $arquivo"
  if ! awk '
  BEGIN { flag = 0; }
  /^\[Software\\\\CodeWeavers\\\\CrossOver\\\\cxoffice\]/ { flag = 1; }
  flag && /^$/ { flag = 0; next; }
  !flag
  ' "$arquivo" > "$temp_arquivo"; then
    logFileAction "rewrite:error" "$temp_arquivo" "failed to write filtered file"
    return 1
  fi

  logFileAction "rewrite:temp:result" "$temp_arquivo" "$(describePath "$temp_arquivo")"
  logFileAction "rewrite:replace" "$arquivo" "moving $temp_arquivo into place"
  if ! mv "$temp_arquivo" "$arquivo"; then
    logFileAction "rewrite:error" "$arquivo" "failed to replace original file"
    return 1
  fi

  logFileAction "rewrite:result" "$arquivo" "$(describePath "$arquivo")"
}

function resetBottle {
  local bottlePath="$1"
  local bottleName=$(basename "$bottlePath")

  logInfo "Resetting bottle $bottleName at $bottlePath"
  if ! removePath "$bottlePath/.version"; then
    logInfo "reset:error -> $bottlePath/.version"
    return 1
  fi

  if ! removePath "$bottlePath/.update-timestamp"; then
    logInfo "reset:error -> $bottlePath/.update-timestamp"
    return 1
  fi

  if ! resetSystemReg "$bottlePath/system.reg"; then
    logInfo "reset:error -> $bottlePath/system.reg"
    return 1
  fi

  echo "\033[32m$bottleName reseted\033[0m"
}

function find_bottles() {
  logFileAction "scan:start" "$1" "searching for system.reg"
  find "$1" -name "system.reg" -exec dirname {} \;
}

addStep "Executing renew trial"
currentDate=$(date +"%Y-%m-%d %H:%M:%S")
prefWriteFailed=0
writePreferenceDate "FirstRunDate" "$currentDate" || prefWriteFailed=1
writePreferenceDate "SULastCheckTime" "$currentDate" || prefWriteFailed=1

if [[ "$prefWriteFailed" -eq 0 ]]; then
  echo "\033[32mTrial start date updated to $currentDate\033[0m"
else
  echo "\033[31mTrial start date update failed for one or more writes\033[0m"
fi

addStep "Finding bottles paths..."
bottlePaths=$(find_bottles "$BOTTLES_PATH")

if [[ -z "$bottlePaths" ]]; then
echo "No bottles were found in the default path. Please enter the bottle path:"
read userBottlePath
# Try to find bottles in the path provided by the user
bottlePaths=$(find_bottles "$userBottlePath")

# If no path is found, the script ends with an error message
if [[ -z "$bottlePaths" ]]; then
  echo "\033[31mNo bottles were found in the provided path. Exiting.\033[0m"
  exit 1
fi
fi

# Fix IFS to handle spaces in the path
OLD_IFS="$IFS"
IFS=$'\n'
for bottle in $bottlePaths; do
logFileAction "scan:match" "$bottle/system.reg" "bottle directory $(basename "$bottle")"
echo "\033[32m$(basename "$bottle")\033[0m -> $bottle"
done

addStep "Resetting bottles install times"
for bottle in $bottlePaths; do
resetBottle "$bottle"
done

IFS="$OLD_IFS"
